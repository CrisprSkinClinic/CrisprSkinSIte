---
// src/components/BookingCalendar.astro
import { siteConfig } from '../config/site.js';
const { defaultService, defaultDoctorId } = Astro.props;
---

<div
  id="bookingCalendarRoot"
  data-default-service={defaultService || ''}
  data-default-doctor-id={defaultDoctorId || ''}
  class="max-w-5xl mx-auto p-8 bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl shadow-2xl flex flex-col md:flex-row gap-8"
>

  <div class="md:w-1/2 space-y-5 pr-0 md:pr-8 border-b md:border-b-0 md:border-r border-slate-200/60 pb-8 md:pb-0">
    <h3 class="text-2xl font-bold text-brand-900 mb-6">Patient Details</h3>

    <div class="flex gap-3">
      <select id="prefix" class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none w-1/4">
        <option value="Mr.">Mr.</option>
        <option value="Ms.">Ms.</option>
        <option value="Mrs.">Mrs.</option>
        <option value="Dr.">Dr.</option>
      </select>
      <input type="text" id="firstName" placeholder="First Name" required class="p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none w-3/4" />
    </div>

    <input type="text" id="lastName" placeholder="Last Name" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none" />
    <input type="tel" id="phone" placeholder="Mobile Number (+91...)" required class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none" />

    <select id="doctor" class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none">
      <option value="" disabled selected>Select Doctor...</option>
      <option value="any">No preference -- show me all available times</option>
      {siteConfig.doctors.map((doc) => (
        <option value={doc.dbId}>{doc.name}</option>
      ))}
    </select>

    <select id="service" class="w-full p-3 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none">
      <option value="" disabled>Select Service...</option>
      <option value="General Consultation">General Dermatology Consultation</option>
      <optgroup label="Hair">
        <option value="Hair Transplant (FUE)">Hair Transplant (FUE)</option>
        <option value="Hair Loss">Hair Loss</option>
        <option value="Female Hair Loss">Female Hair Loss</option>
        <option value="Alopecia Areata">Alopecia Areata</option>
        <option value="Dandruff">Dandruff</option>
      </optgroup>
      <optgroup label="Skin">
        <option value="Acne">Acne</option>
        <option value="Acne Scars">Acne Scars</option>
        <option value="Pigmentation">Pigmentation</option>
        <option value="Melasma">Melasma</option>
        <option value="Vitiligo">Vitiligo</option>
        <option value="Psoriasis">Psoriasis</option>
        <option value="Eczema">Eczema</option>
        <option value="Urticaria">Urticaria</option>
        <option value="Skin Allergy">Skin Allergy</option>
        <option value="Fungal Infections">Fungal Infections</option>
        <option value="Warts, Moles & Skin Tags">Warts, Moles & Skin Tags</option>
        <option value="Nail Disorders">Nail Disorders</option>
      </optgroup>
      <optgroup label="Cosmetic">
        <option value="Chemical Peels">Chemical Peels</option>
        <option value="Botox">Botox</option>
        <option value="Fillers">Fillers</option>
        <option value="Laser Hair Reduction">Laser Hair Reduction</option>
        <option value="Anti-ageing">Anti-ageing</option>
        <option value="Skin Rejuvenation">Skin Rejuvenation</option>
      </optgroup>
      <optgroup label="Pediatric">
        <option value="Pediatric Dermatology">Pediatric Dermatology</option>
        <option value="Birthmarks">Birthmarks</option>
        <option value="Atopic Dermatitis">Atopic Dermatitis</option>
        <option value="Viral Skin Infections">Viral Skin Infections</option>
      </optgroup>
    </select>
  </div>

  <div class="md:w-1/2 flex flex-col">
    <h3 class="text-2xl font-bold text-brand-900 mb-6">Select Slot</h3>

    <input type="date" id="date" required class="w-full p-3 mb-6 rounded-xl bg-white/80 border border-slate-200 focus:ring-2 focus:ring-brand-500 outline-none" />

    <div id="slotsContainer" class="grid grid-cols-2 gap-3 mb-8">
      <p class="col-span-2 text-slate-400 text-sm">Select a doctor and date to see available times.</p>
    </div>

    <button id="confirmBtn" class="mt-auto w-full py-4 bg-brand-900 text-white font-bold rounded-xl shadow-lg hover:bg-brand-800 transition disabled:opacity-50">
      Confirm Appointment
    </button>

    <div id="successMessage" class="hidden mt-4 text-center p-3 bg-green-100 text-green-800 rounded-lg font-medium">
      Appointment confirmed successfully!
    </div>

    <div id="errorMessage" class="hidden mt-4 text-center p-3 bg-red-100 text-red-800 rounded-lg font-medium"></div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    let selectedTime = "";
    let selectedSlotDoctorIds = null; // set when booking without a doctor preference

    const root = document.getElementById('bookingCalendarRoot');
    const dateInput = document.getElementById('date');
    const slotsContainer = document.getElementById('slotsContainer');
    const confirmBtn = document.getElementById('confirmBtn');
    const successMessage = document.getElementById('successMessage');
    const errorMessage = document.getElementById('errorMessage');
    const serviceSelect = document.getElementById('service');
    const doctorSelect = document.getElementById('doctor');

    const todayStr = new Date().toISOString().split('T')[0];
    if (dateInput) {
      dateInput.min = todayStr;
      dateInput.value = todayStr;
    }

    // Randomize the doctor dropdown order on each page load, so no doctor
    // is positioned first by default (this runs before the defaultDoctorId
    // pre-selection below, so a page that intentionally pre-selects a
    // specific doctor, e.g. pediatric-dermatology -> Narayanan A, still
    // works correctly regardless of the shuffled order).
    if (doctorSelect) {
      const placeholderOption = doctorSelect.querySelector('option[value=""]');
      const noPreferenceOption = doctorSelect.querySelector('option[value="any"]');
      const doctorOptions = Array.from(doctorSelect.options).filter(
        (opt) => opt.value !== '' && opt.value !== 'any'
      );
      for (let i = doctorOptions.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [doctorOptions[i], doctorOptions[j]] = [doctorOptions[j], doctorOptions[i]];
      }
      doctorSelect.innerHTML = '';
      if (placeholderOption) doctorSelect.appendChild(placeholderOption);
      if (noPreferenceOption) doctorSelect.appendChild(noPreferenceOption);
      doctorOptions.forEach((opt) => doctorSelect.appendChild(opt));
    }

    // Pre-select the doctor when this booking form is embedded on a
    // doctor-specific page (e.g. that doctor's own bio page), read from
    // the data-default-doctor-id attribute set in the frontmatter above.
    const defaultDoctorId = root?.dataset.defaultDoctorId;
    if (doctorSelect && defaultDoctorId) {
      const matchingDoctorOption = Array.from(doctorSelect.options).find(
        (opt) => opt.value === defaultDoctorId
      );
      if (matchingDoctorOption) {
        doctorSelect.value = defaultDoctorId;
      }
    }

    // Pre-select the service based on which landing page (or service
    // page) this booking form is embedded in, read from the
    // data-default-service attribute set in the frontmatter above.
    // Falls back to the placeholder if the value doesn't match any option.
    const defaultService = root?.dataset.defaultService;
    if (serviceSelect && defaultService) {
      const matchingOption = Array.from(serviceSelect.options).find(
        (opt) => opt.value === defaultService
      );
      if (matchingOption) {
        serviceSelect.value = defaultService;
      }
    }

    function showError(message) {
      errorMessage.textContent = message;
      errorMessage?.classList.remove('hidden');
    }

    function renderSlots(slots) {
      selectedTime = "";
      selectedSlotDoctorIds = null;
      if (slots.length === 0) {
        slotsContainer.innerHTML = '<p class="col-span-2 text-slate-500 text-sm">No slots available on this date. Please try another day, or call us directly.</p>';
        return;
      }
      slotsContainer.innerHTML = '';
      slots.forEach((slot, index) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'time-slot py-3 border border-brand-200 rounded-lg text-brand-800 hover:bg-brand-50 transition font-medium';
        btn.textContent = slot.display;
        btn.dataset.time = slot.display;
        btn.addEventListener('click', () => {
          document.querySelectorAll('.time-slot').forEach((b) => b.classList.remove('bg-brand-600', 'text-white'));
          btn.classList.add('bg-brand-600', 'text-white');
          selectedTime = slot.display;
          selectedSlotDoctorIds = slot.doctorIds || null;
        });
        slotsContainer.appendChild(btn);

        // Auto-select the first available slot, while still letting
        // the user click a different one afterward.
        if (index === 0) {
          btn.classList.add('bg-brand-600', 'text-white');
          selectedTime = slot.display;
          selectedSlotDoctorIds = slot.doctorIds || null;
        }
      });
    }

    // Fetches available slots from the public-available-slots Netlify
    // Function, which computes availability against AppointmentManager's
    // real slot_templates/schedule_overrides/appointments tables --
    // replacing the old direct queries against eye-clinic-site's own,
    // now-stale schedule_sessions/blocked_dates/blocked_slots tables.
    async function loadAvailableSlots(dateStr) {
      const doctorId = doctorSelect?.value;
      if (!doctorId) {
        slotsContainer.innerHTML = '<p class="col-span-2 text-slate-400 text-sm">Select a doctor to see available times.</p>';
        return;
      }

      slotsContainer.innerHTML = '<p class="col-span-2 text-slate-400 text-sm">Checking availability...</p>';
      errorMessage?.classList.add('hidden');

      try {
        // "any" means no preference -- omit doctorId so the function
        // fans out across all three doctors and returns merged slots.
        const doctorParam = doctorId === 'any' ? '' : `&doctorId=${encodeURIComponent(doctorId)}`;
        const response = await fetch(`/.netlify/functions/public-available-slots?date=${encodeURIComponent(dateStr)}${doctorParam}`);
        const data = await response.json();

        if (!response.ok || data.error) {
          throw new Error(data.error || 'Could not load availability.');
        }

        if (data.reason) {
          slotsContainer.innerHTML = `<p class="col-span-2 text-slate-500 text-sm">${data.reason}</p>`;
          return;
        }

        renderSlots(data.slots || []);
      } catch (err) {
        console.error("Error loading availability:", err);
        slotsContainer.innerHTML = '<p class="col-span-2 text-red-500 text-sm">Could not load availability. Please try again.</p>';
      }
    }

    dateInput?.addEventListener('change', (e) => {
      const selectedDate = e.target.value;
      if (selectedDate) loadAvailableSlots(selectedDate);
    });

    doctorSelect?.addEventListener('change', () => {
      if (dateInput?.value) loadAvailableSlots(dateInput.value);
    });

    // Load today's slots immediately on page load only if a doctor is
    // already selected (e.g. pre-selected via defaultDoctorId) -- otherwise
    // wait for the patient to pick one, since availability is doctor-specific.
    if (dateInput?.value && doctorSelect?.value) {
      loadAvailableSlots(dateInput.value);
    }

    if (confirmBtn) {
      confirmBtn.addEventListener('click', async () => {
        const prefix = document.getElementById('prefix').value;
        const fName = document.getElementById('firstName').value;
        const lName = document.getElementById('lastName').value;
        const phone = document.getElementById('phone').value;
        const doctorId = doctorSelect?.value;
        const service = document.getElementById('service').value;
        const date = dateInput.value;

        errorMessage?.classList.add('hidden');

        if (!fName || !phone || !doctorId || !service || !date || !selectedTime) {
          showError("Please fill in all details, select a doctor, and choose an available time slot.");
          return;
        }

        // "any" (no preference) bookings don't have a single doctorId --
        // they carry the list of doctors actually free at the selected
        // time, and the server picks one at random and re-verifies
        // availability before committing.
        const isNoPreference = doctorId === 'any';
        if (isNoPreference && (!selectedSlotDoctorIds || selectedSlotDoctorIds.length === 0)) {
          showError("That time slot's doctor information is missing. Please reselect a time.");
          return;
        }

        // patients.name in AppointmentManager is a single text column,
        // so prefix/first/last are concatenated here -- the split-name
        // concept ends at this form layer.
        const name = `${prefix} ${fName} ${lName}`.trim();

        try {
          confirmBtn.innerText = "Securing Slot...";
          confirmBtn.disabled = true;

          const response = await fetch('/.netlify/functions/public-book-appointment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name,
              phone,
              ...(isNoPreference
                ? { candidateDoctorIds: selectedSlotDoctorIds }
                : { doctorId }),
              service,
              date,
              time: selectedTime,
            }),
          });

          const result = await response.json();

          if (!response.ok || !result.success) {
            throw new Error(result.error || "Could not complete your booking. Please try again or call us directly.");
          }

          // Temporary diagnostic -- remove once booking_completed is
          // confirmed showing up correctly in GA4 Realtime.
          console.log('Booking success block reached, about to fire gtag');
          window.gtag?.('event', 'booking_test');

          window.gtag?.('event', 'booking_completed', {
            event_category: 'conversion',
            event_label: service,
          });

          successMessage?.classList.remove('hidden');
          confirmBtn.style.display = 'none';

        } catch (err) {
          console.error("Error booking:", err);
          showError(err.message || "Could not complete your booking. Please try again or call us directly.");
          confirmBtn.innerText = "Confirm Appointment";
          confirmBtn.disabled = false;
        }
      });
    }
  });
</script>
