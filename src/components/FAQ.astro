---
import { getCollection } from 'astro:content';

const { limit } = Astro.props;

const allFaqs = await getCollection('faqs');
const sortedAll = allFaqs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const sortedFaqs = limit ? sortedAll.slice(0, limit) : sortedAll;

// This creates the invisible SEO code for Google
const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": sortedFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.body // This pulls the Markdown content
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<section class="py-24 px-6 bg-white border-t border-stone-400/15">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-3xl font-medium text-ink mb-12 text-center">Frequently Asked Questions</h2>
    
    <div class="divide-y divide-stone-400/15 border-t border-stone-400/15">
      {sortedFaqs.map((faq) => (
        <details class="group py-6">
          <summary class="flex items-center justify-between gap-6 cursor-pointer text-base text-ink font-medium list-none">
            {faq.data.question}
            <span class="shrink-0 transition-transform duration-300 group-open:rotate-45 text-brand-500">
              <svg fill="none" height="18" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="18"><path d="M12 5v14M5 12h14"></path></svg>
            </span>
          </summary>
          <div class="pt-4 text-stone-600 leading-relaxed max-w-2xl">
            {faq.body}
          </div>
        </details>
      ))}
    </div>

    {limit && allFaqs.length > limit && (
      <div class="text-center mt-10">
        <a href="/faq" class="inline-flex items-center gap-1.5 text-sm text-ink border-b border-ink hover:text-brand-600 hover:border-brand-500 transition-colors">
          View all FAQs <span aria-hidden="true">→</span>
        </a>
      </div>
    )}
  </div>
</section>
