---
// Reusable accordion for service/condition pages. Unlike FAQ.astro
// (which reads the global faqs collection directly with a limit prop),
// this takes already-resolved { question, answer } entries -- so it
// can render content sourced from faqIds (central repo) as well as
// any inline-written FAQs, with identical markup either way.
//
// `entries`: Array<{ question: string, answer: string }>
// `title`: optional heading override (defaults to "Frequently Asked Questions")
const { entries, title = "Frequently Asked Questions" } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": entries.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

{entries && entries.length > 0 && (
  <>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <section class="py-16 px-6 max-w-3xl mx-auto border-t border-stone-400/15">
      <h2 class="font-display text-2xl font-medium text-ink mb-8">{title}</h2>

      <div class="divide-y divide-stone-400/15 border-t border-stone-400/15">
        {entries.map((faq) => (
          <details class="group py-6">
            <summary class="flex items-center justify-between gap-6 cursor-pointer text-base text-ink font-medium list-none">
              {faq.question}
              <span class="shrink-0 transition-transform duration-300 group-open:rotate-45 text-brand-500">
                <svg fill="none" height="18" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="18"><path d="M12 5v14M5 12h14"></path></svg>
              </span>
            </summary>
            <div class="pt-4 text-stone-600 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </>
)}
