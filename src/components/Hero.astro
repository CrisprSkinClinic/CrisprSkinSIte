---
import { siteConfig } from '../config/site.js';
const { title, subtitle, eyebrow, credentials, ctaText, whatsappText } = Astro.props;
---

<section class="relative bg-paper-50 pt-20 pb-20 md:pt-28 md:pb-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-end">

      <!-- Text column -->
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-500 mb-6">{credentials}</p>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-medium text-ink leading-[1.08] mb-6 max-w-xl">
          {eyebrow && <span class="block text-brand-500 text-2xl sm:text-3xl italic font-normal mb-2">{eyebrow}</span>}
          {title}
        </h1>

        <p class="text-lg text-stone-600 mb-10 leading-relaxed max-w-lg">
          {subtitle}
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a href="/book" class="w-full sm:w-auto bg-ink text-white text-base px-8 py-4 hover:bg-brand-600 transition-colors duration-300 text-center">
            {ctaText}
          </a>
          <a href={siteConfig.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto border border-stone-400/30 text-ink text-base px-8 py-4 hover:border-ink transition-colors duration-300 flex items-center justify-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            {whatsappText}
          </a>
        </div>
      </div>

      <!-- Image column -->
      <div class="lg:col-span-5">
        <div class="border border-stone-400/15 aspect-[4/5] overflow-hidden">
          <img 
            src="/images/hero-doctor.jpg" 
            alt="AIIMS-trained dermatology team at CRISPR Skin and Hair Clinic" 
            class="w-full h-full object-cover"
            onerror="this.onerror=null;this.src='https://placehold.co/640x800/F3F5F3/141412?text=CRISPR+Skin+%26+Hair'"
          />
        </div>
        <div class="flex items-center gap-2.5 mt-4 pt-4 border-t border-stone-400/15">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p class="text-sm text-stone-600">Evidence-based, ethical treatment</p>
        </div>
      </div>

    </div>
  </div>
</section>
