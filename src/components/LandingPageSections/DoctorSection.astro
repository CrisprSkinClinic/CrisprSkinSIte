---
// src/components/LandingPageSections/DoctorSection.astro
// Landing-page trust block. Shows the full clinical team rather than
// any single doctor -- this is a 3-doctor equal partnership, and no
// individual should be defaulted to as "the" face of the clinic.
import { siteConfig } from '../../config/site.js';
---

<section class="py-20 px-6 bg-paper-100 border-y border-stone-400/15">
 <div class="max-w-5xl mx-auto">
  <div class="text-center mb-12">
   <h3 class="font-display text-2xl md:text-3xl font-medium text-ink tracking-tight mb-3">Meet Our Doctors</h3>
   <p class="text-stone-600 max-w-2xl mx-auto">Three AIIMS-trained consultant dermatologists, committed to providing ethical, evidence-based care -- prioritizing your long-term skin and hair health over high-volume transactions.</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
   {siteConfig.doctors.map((doc) => (
    <div class="text-center">
     <div class="w-28 h-28 mx-auto mb-4 border border-stone-400/15 overflow-hidden">
      <img
       src={`/images/doctors/${doc.slug}.jpg`}
       alt={doc.name}
       class="w-full h-full object-cover"
       onerror={`this.onerror=null;this.src='https://placehold.co/200x200/F3F0F6/1A1D1F?text=${encodeURIComponent(doc.name)}'`}
      />
     </div>
     <h4 class="font-display text-lg font-medium text-ink">{doc.name}</h4>
     <p class="text-xs text-brand-500 uppercase tracking-[0.1em] mt-1">{doc.designation}</p>
    </div>
   ))}
  </div>
  <div class="text-center mt-12">
   <a href="/our-doctors" class="text-sm text-ink border-b border-ink hover:text-brand-600 hover:border-brand-500 transition-colors">
    View Full Credentials
   </a>
  </div>
 </div>
</section>
