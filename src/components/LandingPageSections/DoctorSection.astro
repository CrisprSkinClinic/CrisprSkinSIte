---
// src/components/LandingPageSections/DoctorSection.astro
// Landing-page trust block. Shows the full clinical team rather than
// any single doctor -- this is a 3-doctor equal partnership, and no
// individual should be defaulted to as "the" face of the clinic.
import { siteConfig } from '../../config/site.js';
---

<section class="py-16 px-6 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="bg-gradient-to-br from-brand-50 to-white rounded-3xl border border-brand-100 shadow-sm p-8 md:p-12">
      <div class="text-center mb-10">
        <h3 class="text-2xl md:text-3xl font-extrabold text-brand-900 tracking-tight mb-2">Meet Our Doctors</h3>
        <p class="text-slate-600 max-w-2xl mx-auto">Three AIIMS-trained consultant dermatologists, committed to providing ethical, evidence-based care -- prioritizing your long-term skin and hair health over high-volume transactions.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        {siteConfig.doctors.map((doc) => (
          <div class="text-center">
            <img
              src={`/images/doctors/${doc.slug}.jpg`}
              alt={doc.name}
              class="w-28 h-28 rounded-full object-cover border-4 border-white shadow-md mx-auto mb-4"
              onerror={`this.onerror=null;this.src='https://placehold.co/200x200/EAF0EC/234B3A?text=${encodeURIComponent(doc.name)}'`}
            />
            <h4 class="text-lg font-extrabold text-brand-900">{doc.name}</h4>
            <p class="text-xs text-brand-600 font-bold uppercase tracking-widest">{doc.designation}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/our-doctors" class="inline-block bg-brand-100 text-brand-800 px-6 py-2.5 rounded-lg font-semibold hover:bg-brand-200 transition text-sm">
          View Full Credentials
        </a>
      </div>
    </div>
  </div>
</section>
