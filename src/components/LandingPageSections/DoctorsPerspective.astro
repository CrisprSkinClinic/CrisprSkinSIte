---
// src/components/LandingPageSections/DoctorsPerspective.astro
//
// Supports two formats: a free-form perspective string (used by
// earlier pages like Cataract/LASIK), and a standardized
// "patient concern -> response" structure (used going forward) for
// consistency across pages while content stays page-specific.
//
// This is a first-person attributed quote, so the speaking doctor
// must be passed explicitly per page via doctorSlug (matching a slug
// in siteConfig.doctors) -- it intentionally does NOT fall back to
// any single doctor by default, since this is a 3-doctor equal
// partnership and no individual should be the silent default author
// of every quote across the site. Pick whichever doctor's specialty
// actually fits the page's topic.
import { siteConfig } from '../../config/site.js';

interface Props {
 perspective?: string;
 patientConcern?: string;
 response?: string;
 doctorSlug: string;
}

const { perspective, patientConcern, response, doctorSlug } = Astro.props;
const doctor = siteConfig.doctors.find((d) => d.slug === doctorSlug) || siteConfig.doctors[0];
---

<section class="py-16 px-6 bg-white border-t border-stone-400/15">
 <div class="max-w-2xl mx-auto">
  <div class="border border-stone-400/15 p-8 md:p-10">
   <div class="flex items-center gap-3 mb-6">
    <div class="w-11 h-11 border border-stone-400/15 overflow-hidden shrink-0">
     <img
      src={`/images/doctors/${doctor.slug}.jpg`}
      alt={doctor.name}
      class="w-full h-full object-cover"
      onerror={`this.onerror=null;this.src='https://placehold.co/100x100/F3F0F6/1A1D1F?text=${encodeURIComponent(doctor.name)}'`}
     />
    </div>
    <div>
     <p class="font-medium text-ink text-sm">
      {patientConcern ? "What I Commonly Hear From Patients" : `${doctor.name}'s Perspective`}
     </p>
     <p class="text-xs text-brand-500 uppercase tracking-[0.1em] mt-0.5">{doctor.designation}</p>
    </div>
   </div>

   {patientConcern ? (
    <>
     <p class="font-display text-lg text-ink italic mb-3">"{patientConcern}"</p>
     <p class="text-stone-600 leading-relaxed">{response}</p>
    </>
   ) : (
    <p class="font-display text-lg text-ink italic leading-relaxed">"{perspective}"</p>
   )}
  </div>
 </div>
</section>
