---
// src/components/LandingPageSections/ObjectionFAQ.astro
//
// Renders page-specific, hand-written objection-handling FAQs.
// Deliberately NOT derived from the global faqs collection -- each
// page's actual booking objections (Cataract vs. LASIK vs. Diabetic
// Eye) are different, and keyword-filtering an educational FAQ
// collection produced generic "what is this condition" answers
// instead of objection-handling ones.

interface FAQ {
 question: string;
 answer: string;
}

interface Props {
 faqs: FAQ[];
}

const { faqs } = Astro.props;
---

{faqs && faqs.length > 0 && (
 <section class="py-12 px-6 bg-white border-t border-stone-400/15">
  <div class="max-w-2xl mx-auto">
   <h2 class="text-xl md:text-2xl font-medium text-ink mb-6 text-center">A Few Common Questions</h2>
   <div class="space-y-3">
    {faqs.map((faq: FAQ) => (
     <details class="group bg-paper-50 border border-stone-400/15">
      <summary class="flex items-center justify-between cursor-pointer p-4 font-semibold text-ink group-hover:text-brand-600 transition text-sm">
       {faq.question}
       <span class="transition group-open:rotate-180 shrink-0 ml-3">
        <svg fill="none" height="18" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" width="18"><path d="M6 9l6 6 6-6"></path></svg>
       </span>
      </summary>
      <div class="p-4 pt-0 text-stone-600 text-sm leading-relaxed border-t border-stone-400/15 mt-2">
       {faq.answer}
      </div>
     </details>
    ))}
   </div>
  </div>
 </section>
)}
