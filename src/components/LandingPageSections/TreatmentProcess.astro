---
// src/components/LandingPageSections/TreatmentProcess.astro
const { title = "What to Expect", steps = [] } = Astro.props;
---

<section class="py-16 px-6 bg-brand-50/50 border-y border-stone-400/15">
 <div class="max-w-3xl mx-auto">
  <h2 class="text-3xl md:text-4xl font-medium text-ink mb-12 text-center tracking-tight">{title}</h2>
  <div class="space-y-6">
   {steps.map((step: { title: string; description: string }, index: number) => (
    <div class="flex gap-5 items-start bg-white p-6 border border-stone-400/15">
     <div class="shrink-0 w-12 h-12 bg-brand-900 text-white font-medium text-lg flex items-center justify-center">
      {index + 1}
     </div>
     <div class="pt-1">
      <h3 class="font-medium text-ink text-lg mb-1">{step.title}</h3>
      <p class="text-stone-600 leading-relaxed">{step.description}</p>
     </div>
    </div>
   ))}
  </div>
 </div>
</section>
