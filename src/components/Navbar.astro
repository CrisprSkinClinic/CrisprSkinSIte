<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobileMenuBtn');
    const panel = document.getElementById('mobileMenuPanel');
    const iconOpen = document.getElementById('menuIconOpen');
    const iconClose = document.getElementById('menuIconClose');

    if (!btn || !panel || !iconOpen || !iconClose) return;

    btn.addEventListener('click', () => {
      const isHidden = panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(isHidden));
    });

    // Close menu when any link is tapped
    panel.querySelectorAll('nav > a, #mobileServicesSubmenu a, #mobileConditionsSubmenu a').forEach((link) => {
      link.addEventListener('click', () => {
        panel.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });

    // Services submenu toggle
    const servicesToggle = document.getElementById('mobileServicesToggle');
    const servicesSubmenu = document.getElementById('mobileServicesSubmenu');
    const servicesChevron = document.getElementById('mobileServicesChevron');

    if (servicesToggle && servicesSubmenu && servicesChevron) {
      servicesToggle.addEventListener('click', () => {
        const isHidden = servicesSubmenu.classList.contains('hidden');
        servicesSubmenu.classList.toggle('hidden');
        servicesSubmenu.classList.toggle('flex');
        servicesChevron.classList.toggle('rotate-180');
        servicesToggle.setAttribute('aria-expanded', String(isHidden));
      });
    }

    // Conditions submenu toggle (NEW)
    const conditionsToggle = document.getElementById('mobileConditionsToggle');
    const conditionsSubmenu = document.getElementById('mobileConditionsSubmenu');
    const conditionsChevron = document.getElementById('mobileConditionsChevron');

    if (conditionsToggle && conditionsSubmenu && conditionsChevron) {
      conditionsToggle.addEventListener('click', () => {
        const isHidden = conditionsSubmenu.classList.contains('hidden');
        conditionsSubmenu.classList.toggle('hidden');
        conditionsSubmenu.classList.toggle('flex');
        conditionsChevron.classList.toggle('rotate-180');
        conditionsToggle.setAttribute('aria-expanded', String(isHidden));
      });
    }
  });
</script>
