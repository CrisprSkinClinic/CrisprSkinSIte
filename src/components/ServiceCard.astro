---
// Plain <img> with onerror fallback instead of astro:assets Image --
// this component now receives public-path strings (e.g.
// "/images/services/acne.jpg") rather than imported ImageMetadata
// objects, since dermatology service photography doesn't exist yet.
// Once real photos are added under public/images/services/, this can
// be swapped back to optimized Image imports.
const { title, description, link, image, alt } = Astro.props;
---
<a href={link} class="group flex flex-col h-full">
  <div class="aspect-[4/3] overflow-hidden bg-paper-200 border border-stone-400/15">
    <img 
      src={image} 
      alt={alt || title} 
      loading="lazy"
      class="w-full h-full object-cover grayscale-[15%] group-hover:grayscale-0 transition-all duration-500"
      onerror={`this.onerror=null;this.src='https://placehold.co/480x360/F3F0F6/1A1D1F?text=${encodeURIComponent(title)}'`}
    />
  </div>

  <div class="pt-5 flex flex-col flex-grow">
    <h3 class="font-display text-xl font-medium text-ink mb-2">{title}</h3>
    <p class="text-stone-600 text-sm leading-relaxed mb-4 flex-grow">{description}</p>

    <span class="text-sm text-ink inline-flex items-center gap-1.5 w-fit">
      <span class="border-b border-ink group-hover:border-brand-500 group-hover:text-brand-500 transition-colors">Learn more</span>
      <span aria-hidden="true" class="group-hover:translate-x-0.5 transition-transform">&rarr;</span>
    </span>
  </div>
</a>
