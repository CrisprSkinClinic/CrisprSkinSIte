---
// Plain <img> with onerror fallback instead of astro:assets Image --
// this component now receives public-path strings (e.g.
// "/images/services/acne.jpg") rather than imported ImageMetadata
// objects, since dermatology service photography doesn't exist yet.
// Once real photos are added under public/images/services/, this can
// be swapped back to optimized Image imports.
const { title, description, link, image, alt } = Astro.props;
---
<a href={link} class="bg-white rounded-2xl shadow-sm border border-champagne-200 overflow-hidden hover:shadow-xl hover:border-brand-200 transition-all duration-300 group flex flex-col h-full">
  
  <!-- Image Header Container -->
<div class="relative h-48 sm:h-56 overflow-hidden bg-champagne-100 flex items-center justify-center">
  <img 
    src={image} 
    alt={alt || title} 
    loading="lazy"
    class="max-w-full max-h-full object-contain transition-transform duration-700 group-hover:scale-105"
    onerror={`this.onerror=null;this.src='https://placehold.co/480x320/E9DDCF/223154?text=${encodeURIComponent(title)}'`}
  />
    <!-- Subtle gradient overlay to make it look premium -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>
  
  <!-- Text Content Container -->
  <div class="p-6 md:p-8 flex flex-col flex-grow">
    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-brand-600 transition-colors">{title}</h3>
    <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">{description}</p>
    
    <span class="text-brand-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
      Learn More <span aria-hidden="true">&rarr;</span>
    </span>
  </div>
</a>
