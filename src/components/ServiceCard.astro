---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  link: string;
  image?: ImageMetadata | string;
  alt?: string;
  priority?: boolean;
}

const { title, description, link, image, alt, priority = false } = Astro.props;

const isOptimized = image && typeof image === 'object' && 'src' in image;
---
<a href={link} class="bg-white rounded-2xl shadow-sm border border-champagne-200 overflow-hidden hover:shadow-xl hover:border-brand-200 transition-all duration-300 group flex flex-col h-full">
  
  <div class="relative aspect-square overflow-hidden bg-champagne-50">
    {isOptimized ? (
      <Image
        src={image}
        alt={alt || title}
        width={500}
        height={500}
        widths={[300, 400, 500]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        formats={['avif', 'webp']}
        quality={80}
        loading={priority ? "eager" : "lazy"}
        class="w-full h-full object-contain p-2 transition-transform duration-500 group-hover:scale-[1.02]"
      />
    ) : (
      <img 
        src={typeof image === 'string' ? image : 'https://placehold.co/500x500/F7F2EB/223154?text=Service'}
        alt={alt || title}
        width="500"
        height="500"
        loading={priority ? "eager" : "lazy"}
        decoding="async"
        class="w-full h-full object-contain p-2 transition-transform duration-500 group-hover:scale-[1.02]"
        onerror={`this.onerror=null;this.src='https://placehold.co/500x500/F7F2EB/223154?text=${encodeURIComponent(title)}'`}
      />
    )}
  </div>
  
  <div class="p-6 md:p-8 flex flex-col flex-grow">
    <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-brand-600 transition-colors">{title}</h3>
    <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">{description}</p>
    <span class="text-brand-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
      Learn More <span aria-hidden="true">&rarr;</span>
    </span>
  </div>
</a>
