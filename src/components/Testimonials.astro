---
// Real Google reviews, curated 2-per-doctor from CRISPR_Google_Reviews_Compiled.xlsx.
// Names shown as written on Google, formatted to consistent title case.
// Quotes are trimmed to a representative excerpt of the original review
// (full text is longer in most cases) -- trimmed for card length, not
// reworded, per the user's explicit instruction to keep them real
// excerpts rather than paraphrase.

const reviews = [
  {
    name: "Varun Shenoy",
    doctorSlug: "dr-karthik-l",
    doctorName: "Dr. Karthik L",
    quote: "I have undergone hair transplant surgery performed by Dr Karthik L & Dr Narayanan B. The surgery was done to their fullest effort and great expertise. I had no swelling post surgery. Trustworthy and highly recommended."
  },
  {
    name: "Soundarya Balaji",
    doctorSlug: "dr-karthik-l",
    doctorName: "Dr. Karthik L",
    quote: "Dr. Karthik performed wart removal on our little one. He was very patient in addressing the issue to us and explained the process beforehand. He was smooth and quick during the procedure."
  },
  {
    name: "Sakthivel Kanakavelu",
    doctorSlug: "dr-narayanan-a",
    doctorName: "Dr. Narayanan A",
    quote: "His kindness, focused listening, and thorough analysis of my skin condition stood out from the very beginning. Thanks to his accurate diagnosis and prompt treatment, my skin issues were resolved in the shortest possible time."
  },
  {
    name: "Balasubramanian S.N.",
    doctorSlug: "dr-narayanan-a",
    doctorName: "Dr. Narayanan A",
    quote: "The Doctor is mild mannered, and very amiable in nature. He inspected the affected portions and gave positive diagnosis... would willingly suggest and recommend his name for anything concerned with hair and skin."
  },
  {
    name: "VVP Comps",
    doctorSlug: "dr-narayanan-b",
    doctorName: "Dr. Narayanan B",
    quote: "The way of communicating with the patients is inspiring. His detailed analysis is very attractive. He doesn't unnecessarily prescribe extra medicines. I am seeing a good result in my treatment."
  },
  {
    name: "Varun Shenoy",
    doctorSlug: "dr-narayanan-b",
    doctorName: "Dr. Narayanan B",
    quote: "The surgery was done to their fullest effort and great expertise. Pre and post surgical care was great and I am extremely satisfied. Trustworthy and highly recommended."
  },
];
---

<section class="bg-brand-50/50 py-20 px-6 border-y border-champagne-200">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-900 mb-4">Patient Stories</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Read about the experiences of patients who trusted CRISPR Skin and Hair Clinic with their care.</p>
    </div>
    
    <div class="flex md:grid md:grid-cols-3 gap-6 md:gap-8 overflow-x-auto md:overflow-visible snap-x snap-mandatory scroll-smooth pb-4 -mx-6 px-6 md:mx-0 md:px-0">
      {reviews.map((review) => (
        <div class="shrink-0 w-[85vw] sm:w-80 md:w-auto snap-start bg-white p-8 rounded-2xl shadow-sm border border-champagne-200 relative group hover:shadow-md hover:border-brand-200 transition-all duration-300 flex flex-col">
          <!-- Decorative Quote Icon -->
          <div class="text-brand-100 absolute top-6 right-6 group-hover:text-brand-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          
          <!-- 5-Star Rating -->
          <div class="flex gap-1 mb-6 text-amber-400">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          
          <!-- Quote Text -->
          <p class="text-slate-700 mb-8 relative z-10 leading-relaxed italic flex-grow">
            "{review.quote}"
          </p>
          
          <!-- Patient Info -->
          <div class="mt-auto pt-6 border-t border-champagne-200">
            <p class="font-extrabold text-slate-900">{review.name}</p>
            <a href={`/our-doctors/${review.doctorSlug}`} class="text-sm text-brand-600 font-semibold uppercase tracking-wider mt-1 hover:underline inline-block">
              Patient of {review.doctorName}
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="https://share.google/VOkSEAUYVlRCSgVgT"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-700 font-bold hover:underline"
      >
        Read all our reviews on Google &rarr;
      </a>
    </div>
  </div>
</section>
