---
// PLACEHOLDER REVIEWS -- replace with real, consented patient
// testimonials before launch. Do not publish fabricated quotes
// attributed to named patients; medical testimonial advertising is
// tightly regulated (MCI/NMC guidelines) and fake reviews carry real
// legal and reputational risk. Swap each entry below for an actual
// review once collected, or wire this up to Google Reviews.
const reviews = [
  {
    name: "Patient testimonial pending",
    service: "Hair Transplant",
    quote: "Add a real, consented patient review here before launch."
  },
  {
    name: "Patient testimonial pending",
    service: "Acne Treatment",
    quote: "Add a real, consented patient review here before launch."
  },
  {
    name: "Patient testimonial pending",
    service: "Cosmetic Dermatology",
    quote: "Add a real, consented patient review here before launch."
  }
];
---

<section class="bg-paper-100 py-24 px-6 border-y border-stone-400/15">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl font-medium text-ink mb-4">Patient Stories</h2>
      <p class="text-lg text-stone-600 max-w-2xl mx-auto">Read about the experiences of patients who trusted CRISPR Skin and Hair Clinic with their care.</p>
    </div>
    
    <div class="flex md:grid md:grid-cols-3 gap-8 md:gap-10 overflow-x-auto md:overflow-visible snap-x snap-mandatory scroll-smooth pb-4 -mx-6 px-6 md:mx-0 md:px-0">
      {reviews.map((review) => (
        <div class="shrink-0 w-[85vw] sm:w-80 md:w-auto snap-start bg-white p-8 border border-stone-400/15 flex flex-col">
          <p class="font-display text-xl text-ink italic leading-snug mb-8 flex-grow">
            "{review.quote}"
          </p>
          
          <div class="pt-6 border-t border-stone-400/15">
            <p class="text-sm font-medium text-ink">{review.name}</p>
            <p class="text-xs text-brand-500 uppercase tracking-[0.1em] mt-1">{review.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
