---
// Testimonials now live in src/content/testimonials/ (managed via
// /staff-admin -> "Testimonials" tab) rather than hardcoded here, so
// staff can add/remove/reorder which reviews are featured without a
// code change. Only entries with active: true are shown, sorted by
// the optional `order` field (undefined orders sort last).
import { getCollection } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
const reviews = allTestimonials
  .filter((t) => t.data.active)
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((t) => ({
    name: t.data.name,
    rating: t.data.rating,
    doctorSlug: t.data.doctorSlug,
    doctorName: t.data.doctorName,
    quote: t.body.trim(),
  }));
---

<section class="bg-brand-50/50 py-20 px-6 border-y border-champagne-200">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-900 mb-4">Patient Stories</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-4">Read about the experiences of patients who trusted CRISPR Skin and Hair Clinic with their care.</p>
      <div id="liveGoogleRating" class="hidden inline-flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-champagne-200 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <span id="liveGoogleRatingText" class="font-bold text-slate-900 text-sm"></span>
        <a id="liveGoogleRatingLink" href="https://share.google/VOkSEAUYVlRCSgVgT" target="_blank" rel="noopener noreferrer" class="text-sm text-brand-600 font-semibold hover:underline">on Google</a>
      </div>
    </div>
    
    <div id="testimonialsTrack" class="flex md:grid md:grid-cols-3 gap-6 md:gap-8 overflow-x-auto md:overflow-visible snap-x snap-mandatory scroll-smooth pb-4 -mx-6 px-6 md:mx-0 md:px-0">
      {reviews.map((review) => (
        <div class="shrink-0 w-[85vw] sm:w-80 md:w-auto snap-start bg-white p-8 rounded-2xl shadow-sm border border-champagne-200 relative group hover:shadow-md hover:border-brand-200 transition-all duration-300 flex flex-col">
          <!-- Decorative Quote Icon -->
          <div class="text-brand-100 absolute top-6 right-6 group-hover:text-brand-200 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>
          
          <!-- Star Rating -->
          <div class="flex gap-1 mb-6 text-amber-400">
            {[...Array(review.rating || 5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          
          <!-- Quote Text -->
          <p class="text-slate-700 mb-8 relative z-10 leading-relaxed italic flex-grow">
            "{review.quote}"
          </p>
          
          <!-- Patient Info -->
          <div class="mt-auto pt-6 border-t border-champagne-200">
            <p class="font-extrabold text-slate-900">{review.name}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="https://share.google/VOkSEAUYVlRCSgVgT"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-700 font-bold hover:underline"
      >
        Read all our reviews on Google &rarr;
      </a>
    </div>
  </div>
</section>

<script>
  // Shuffle review order on each visit. This is a static build, so a
  // shuffle done in frontmatter would freeze the same order for every
  // visitor until the next deploy -- doing it client-side here means no
  // doctor's reviews are consistently shown first, matching the same
  // unbiased-order approach used for the doctor grid elsewhere on the site.
  document.addEventListener('astro:page-load', () => {
    const track = document.getElementById('testimonialsTrack');
    if (!track) return;
    const cards = Array.from(track.children);
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    cards.forEach((card) => track.appendChild(card));
  });

  // Fetch the clinic's live overall Google rating (server-side, via
  // get-google-reviews.js -- the API key never reaches the browser).
  // This only shows the aggregate rating/count/link, not Google's raw
  // review text -- the curated, doctor-attributed reviews above remain
  // the primary content; this badge is a lightweight trust signal that
  // stays current without a redeploy.
  document.addEventListener('astro:page-load', async () => {
    const badge = document.getElementById('liveGoogleRating');
    const ratingText = document.getElementById('liveGoogleRatingText');
    const ratingLink = document.getElementById('liveGoogleRatingLink');
    if (!badge || !ratingText) return;

    try {
      const response = await fetch('/.netlify/functions/get-google-reviews');
      if (!response.ok) return;
      const data = await response.json();
      if (!data.overallRating) return;

      const count = data.totalReviewCount ? ` (${data.totalReviewCount} reviews)` : '';
      ratingText.textContent = `${data.overallRating.toFixed(1)}${count}`;
      if (data.mapsUrl && ratingLink) {
        ratingLink.href = data.mapsUrl;
      }
      badge.classList.remove('hidden');
    } catch (err) {
      // Fails silently -- the curated reviews above are the primary
      // content, so a failed live-rating fetch shouldn't show an error
      // to visitors, just leave the badge hidden.
      console.error('Could not load live Google rating:', err);
    }
  });
</script>
