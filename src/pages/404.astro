---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.js';
---

<MainLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
 <section class="min-h-[60vh] flex items-center justify-center px-6 py-20">
  <div class="max-w-lg mx-auto text-center">
   <div class="inline-flex items-center justify-center w-16 h-16 border border-stone-400/15 text-brand-500 mb-8">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
     <circle cx="12" cy="12" r="10"/>
     <line x1="8" y1="12" x2="16" y2="12"/>
    </svg>
   </div>

   <h1 class="font-display text-3xl md:text-4xl font-medium text-ink mb-3 tracking-tight">Page Not Found</h1>
   <p class="text-stone-600 text-lg mb-10 leading-relaxed">
    The page you're looking for doesn't exist or may have moved. Let's get you back on track.
   </p>

   <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
    <a href="/" class="w-full sm:w-auto bg-ink text-white text-sm px-8 py-3.5 hover:bg-brand-600 transition-colors duration-300 text-center">
     Go to Homepage
    </a>
    <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="w-full sm:w-auto border border-stone-400/30 text-ink text-sm px-8 py-3.5 hover:border-ink transition-colors duration-300 text-center">
     Call Us: {siteConfig.contact.phone}
    </a>
   </div>

   <div class="mt-12 pt-8 border-t border-stone-400/15">
    <p class="text-xs text-stone-500 mb-4 uppercase tracking-[0.15em]">Popular Pages</p>
    <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm">
     <a href="/services/hair-transplant-fue" class="text-ink hover:text-brand-600 transition-colors">Hair Transplant</a>
     <span class="text-stone-300">&middot;</span>
     <a href="/services/acne" class="text-ink hover:text-brand-600 transition-colors">Acne Treatment</a>
     <span class="text-stone-300">&middot;</span>
     <a href="/our-doctors" class="text-ink hover:text-brand-600 transition-colors">Our Doctors</a>
     <span class="text-stone-300">&middot;</span>
     <a href="/book" class="text-ink hover:text-brand-600 transition-colors">Book Appointment</a>
    </div>
   </div>
  </div>
 </section>
</MainLayout>
