---
import MainLayout from '../layouts/MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config/site.js';
import { getServiceImage, getServiceImageAlt } from '../utils/serviceImages';

export async function getStaticPaths() {
  const categoryContent = {
    hair: {
      label: 'Hair',
      headline: 'Hair Care Services',
      subheadline: 'From surgical restoration to medical management of hair loss and scalp conditions, evaluated and treated by AIIMS-trained dermatologists.',
    },
    skin: {
      label: 'Skin',
      headline: 'Skin Care Services',
      subheadline: 'Evidence-based diagnosis and treatment for acne, pigmentation, chronic skin conditions, infections, and more.',
    },
    cosmetic: {
      label: 'Cosmetic',
      headline: 'Cosmetic Dermatology Services',
      subheadline: 'Conservative, natural-looking cosmetic treatments administered by trained consultant dermatologists -- never a one-size-fits-all package.',
    },
    pediatric: {
      label: 'Pediatric',
      headline: 'Pediatric Dermatology Services',
      subheadline: 'Child-friendly, age-appropriate care for skin, hair, and nail concerns in infants and children.',
    },
  };

  return Object.keys(categoryContent).map((category) => ({
    params: { category },
    props: { content: categoryContent[category] },
  }));
}

const { category } = Astro.params;
const { content } = Astro.props;

const allServices = await getCollection('services');
const services = allServices
  .filter((s) => s.data.category === category)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const pageTitle = content.headline;
const pageDescription = `${content.subheadline} Available at ${siteConfig.name}, KK Nagar, Chennai.`;
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Breadcrumbs items={[
    { name: "Services", url: "/services" },
    { name: content.label, url: `/${category}` }
  ]} />

  <div class="bg-brand-900 text-white py-16 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{content.headline}</h1>
    <p class="text-lg text-brand-200 max-w-2xl mx-auto">{content.subheadline}</p>
  </div>

  <div class="max-w-7xl mx-auto py-16 px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <ServiceCard
          image={getServiceImage(service.data.heroImage) ?? (service.data.heroImage ? `/images/services/${service.data.heroImage}.jpg` : undefined)}
          alt={getServiceImageAlt(service.data.heroImage, service.data.title)}
          title={service.data.title}
          description={service.data.heroSubheadline || service.data.metaDescription || ''}
          link={`/services/${service.slug}`}
        />
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/services" class="inline-block text-brand-700 font-bold hover:underline">View all services &rarr;</a>
    </div>
  </div>
</MainLayout>
