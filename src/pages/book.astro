---
import MainLayout from '../layouts/MainLayout.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import { siteConfig } from '../config/site.js';

const pageTitle = `Book Your Consultation | ${siteConfig.name}`;
const pageDescription = `Schedule your appointment at ${siteConfig.name} in KK Nagar, Chennai. Select your preferred date and time for a specialized evaluation.`;
---

<MainLayout title={pageTitle} description={pageDescription}>
 <section class="bg-paper-50 border-b border-stone-400/15 pt-8 pb-16 md:pb-24 px-6 text-center">
  <div class="max-w-3xl mx-auto">
   <h1 class="font-display text-4xl md:text-5xl font-medium mb-4 text-ink">Book Your Appointment</h1>
   <p class="text-lg text-stone-600">Select an available time slot below to secure your consultation.</p>
  </div>
 </section>

 <section class="py-16 px-6 bg-paper-50 relative -mt-8">
  <BookingCalendar />
 </section>

 <section class="py-12 px-6 max-w-4xl mx-auto text-center border-t border-stone-400/20">
  <h3 class="text-xl font-medium text-ink mb-2">Have questions before booking?</h3>
  <p class="text-slate-600 mb-4">Call us directly and our team will help you choose the right specialist and appointment slot.</p>
  <a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="inline-block bg-brand-100 text-brand-800 font-medium px-6 py-3 hover:bg-brand-200 transition">
   Call {siteConfig.contact.phone}
  </a>
 </section>
</MainLayout>
