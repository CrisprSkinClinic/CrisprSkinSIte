<script is:inline>
  // Register the service worker so Chrome/Edge offer the install
  // prompt. Scoped to /bookings-manager only -- this does not affect
  // any other page on the site.
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/bookings-manager-sw.js', { scope: '/bookings-manager' })
        .catch((err) => console.error('Service worker registration failed:', err));
    });
  }
</script>
