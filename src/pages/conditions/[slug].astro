---
import { getCollection, getEntry } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { siteConfig } from '../../config/site.js';

export async function getStaticPaths() {
 const conditions = await getCollection('conditions');
 return conditions.map((entry) => ({
  params: { slug: entry.slug },
  props: { entry },
 }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const parentService = await getEntry('services', data.parentService);
const relatedConditionEntries = data.relatedConditions
 ? await Promise.all(
   data.relatedConditions.map((slug) => getEntry('conditions', slug))
  )
 : [];

// Resolve faqIds against the central faqs collection.
let faqEntries = [];
if (data.faqIds && data.faqIds.length > 0) {
 const resolved = await Promise.all(
  data.faqIds.map((id) => getEntry('faqs', id))
 );
 faqEntries = resolved
  .filter(Boolean)
  .map((f) => ({ question: f.data.question, answer: f.body }));
}
---

<MainLayout title={data.title} description={data.metaDescription}>
 <Breadcrumbs items={[
  { name: "Services", url: "/services" },
  ...(parentService ? [{ name: parentService.data.title, url: `/services/${parentService.slug}` }] : []),
  { name: data.title, url: `/conditions/${entry.slug}` }
 ]} />

 <section class="pt-8 pb-16 md:pb-24 px-6 bg-paper-50 border-b border-stone-400/15">
  <div class="max-w-3xl mx-auto">
   {data.heroEyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-500 mb-6">{data.heroEyebrow}</p>
   )}
   <h1 class="font-display text-4xl md:text-5xl font-medium mb-6 leading-[1.1] text-ink">{data.heroHeadline}</h1>
   <p class="text-lg text-stone-600 mb-8 leading-relaxed max-w-xl">
    {data.heroSubheadline}
   </p>
   <a href="#book" class="inline-block bg-ink text-white text-base px-8 py-4 hover:bg-brand-600 transition-colors duration-300">
    {data.ctaTitle || `Book an Evaluation`}
   </a>
  </div>
 </section>

 {data.twoPaths && (
  <section class="py-16 px-6 max-w-5xl mx-auto">
   <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-stone-400/15 border border-stone-400/15">
    <div class="bg-white p-8">
     <h2 class="font-display text-xl font-medium text-ink mb-3">{data.twoPaths.screeningTitle}</h2>
     <p class="text-stone-600 leading-relaxed">{data.twoPaths.screeningBody}</p>
    </div>
    <div class="bg-white p-8">
     <h2 class="font-display text-xl font-medium text-ink mb-3">{data.twoPaths.symptomsTitle}</h2>
     <p class="text-stone-600 leading-relaxed">{data.twoPaths.symptomsBody}</p>
    </div>
   </div>
  </section>
 )}

 <section class="py-8 px-6 max-w-3xl mx-auto">
  <div class="prose prose-lg max-w-none text-stone-700 prose-headings:font-display prose-headings:font-medium prose-headings:text-ink prose-a:text-brand-600">
   <h2>What Is It?</h2>
   <Content />
  </div>
 </section>

 {data.riskFactors && data.riskFactors.length > 0 && (
  <section class="py-8 px-6 max-w-3xl mx-auto">
   <h2 class="font-display text-2xl font-medium text-ink mb-6">Risk Factors</h2>
   <ul class="space-y-2 text-stone-600">
    {data.riskFactors.map((item) => (
     <li class="flex items-start gap-3">
      <span class="w-1 h-1 rounded-full bg-brand-500 mt-2.5 shrink-0"></span>
      {item}
     </li>
    ))}
   </ul>
  </section>
 )}

 {data.symptoms && data.symptoms.length > 0 && (
  <section class="py-8 px-6 max-w-3xl mx-auto">
   <h2 class="font-display text-2xl font-medium text-ink mb-6">Symptoms</h2>
   <ul class="space-y-2 text-stone-600">
    {data.symptoms.map((item) => (
     <li class="flex items-start gap-3">
      <span class="w-1 h-1 rounded-full bg-brand-500 mt-2.5 shrink-0"></span>
      {item}
     </li>
    ))}
   </ul>
  </section>
 )}

 {data.treatmentOverview && data.treatmentOverview.length > 0 && (
  <section class="py-8 px-6 max-w-3xl mx-auto">
   <div class="border border-stone-400/15 p-8">
    <h2 class="font-display text-2xl font-medium text-ink mb-5">Treatment</h2>
    <ul class="space-y-4">
     {data.treatmentOverview.map((t) => (
      <li>
       <p class="text-ink font-medium mb-0.5">{t.name}</p>
       <p class="text-stone-600 text-sm leading-relaxed">{t.description}</p>
      </li>
     ))}
    </ul>
    {parentService && (
     <p class="mt-8 pt-6 border-t border-stone-400/15 text-sm">
      <a href={`/services/${parentService.slug}`} class="text-ink border-b border-ink hover:text-brand-600 hover:border-brand-500 transition-colors">
       Learn more about {parentService.data.title} &rarr;
      </a>
     </p>
    )}
   </div>
  </section>
 )}

 {data.urgentScenarios && data.urgentScenarios.length > 0 && (
  <section class="py-8 px-6 max-w-3xl mx-auto">
   <div class="border border-red-200 bg-red-50/50 p-8">
    <h3 class="font-display text-xl font-medium text-red-900 mb-3">{data.urgentCareTitle}</h3>
    {data.urgentCareBody && <p class="text-red-800 leading-relaxed mb-4">{data.urgentCareBody}</p>}
    <ul class="space-y-2 text-red-800">
     {data.urgentScenarios.map((item) => (
      <li class="flex items-start gap-3">
       <span class="w-1 h-1 rounded-full bg-red-500 mt-2.5 shrink-0"></span>
       {item}
      </li>
     ))}
    </ul>
   </div>
  </section>
 )}

 {relatedConditionEntries.length > 0 && (
  <section class="py-16 px-6 max-w-3xl mx-auto border-t border-stone-400/15">
   <h2 class="font-display text-2xl font-medium text-ink mb-6">Related Conditions</h2>
   <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-stone-400/15 border border-stone-400/15">
    {relatedConditionEntries.map((c) => (
     <a href={`/conditions/${c.slug}`} class="block p-5 bg-white hover:bg-paper-50 transition-colors">
      <p class="text-xs text-stone-500 uppercase tracking-[0.1em] mb-1">Related Condition</p>
      <p class="text-ink font-medium">{c.data.title}</p>
     </a>
    ))}
   </div>
  </section>
 )}

 <FAQAccordion entries={faqEntries} />

 <CTA
  title={data.ctaTitle || `Book an Evaluation for ${data.title}`}
  address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
  phone={siteConfig.contact.phone}
 />
</MainLayout>
