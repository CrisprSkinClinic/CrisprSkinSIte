---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import { getCollection, getEntry } from 'astro:content';
import ClinicGallery from '../components/ClinicGallery.astro';
import BookingSection from '../components/LandingPageSections/BookingSection.astro';
import { siteConfig } from '../config/site.js';
import { getServiceImage, getServiceImageAlt } from '../utils/serviceImages';

const featuredServices = [
  { slug: 'hair-transplant-fue', alt: 'Hair transplant procedure', title: 'Hair Transplant (FUE)', description: 'Advanced Follicular Unit Extraction for natural, permanent hair restoration performed by a dedicated hair transplant surgeon.', link: '/services/hair-transplant-fue' },
  { slug: 'acne', alt: 'Acne treatment consultation', title: 'Acne & Acne Scars', description: 'Evidence-based treatment for active acne and the scarring it leaves behind, tailored to your skin type.', link: '/services/acne' },
  { slug: 'pigmentation', alt: 'Skin pigmentation treatment', title: 'Pigmentation & Melasma', description: 'Targeted treatment for stubborn pigmentation and melasma using dermatologist-guided regimens.', link: '/services/pigmentation' },
  { slug: 'vitiligo', alt: 'Vitiligo treatment', title: 'Vitiligo', description: 'Comprehensive evaluation and long-term management of vitiligo with realistic, honest expectations.', link: '/services/vitiligo' },
  { slug: 'botox', alt: 'Cosmetic dermatology treatment', title: 'Botox & Fillers', description: 'Subtle, natural-looking anti-ageing and rejuvenation treatments administered by trained dermatologists.', link: '/services/botox' },
  { slug: 'pediatric-dermatology', alt: 'Pediatric dermatology consultation', title: 'Pediatric Dermatology', description: "A child-friendly approach to eczema, birthmarks, and other skin conditions in infants and children.", link: '/services/pediatric-dermatology' },
];

const featuredConditionSlugs = [
  'androgenetic-alopecia',
  'melasma',
  'vitiligo',
  'plaque-psoriasis',
  'hormonal-acne',
  'childhood-atopic-dermatitis',
];
const featuredConditions = (
  await Promise.all(featuredConditionSlugs.map((slug) => getEntry('conditions', slug)))
).filter(Boolean);

const pageTitle = "Best Skin & Hair Clinic in KK Nagar, Chennai";
const pageDescription = siteConfig.description;

const allPosts = await getCollection('blog') || [];
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Hero 
    title="Skin, Hair & Aesthetic Dermatology Specialists" 
    subtitle="AIIMS-trained dermatologists in KK Nagar, Chennai offering hair transplantation, medical dermatology, and cosmetic treatments. Evidence-based care, no unnecessary procedures."
    eyebrow={siteConfig.name}
    credentials="AIIMS-trained dermatology team"
    ctaText="Book Consultation"
    whatsappText="Chat on WhatsApp"
  />

  <section class="py-16 px-6 max-w-7xl mx-auto" id="services">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-900 mb-4">Complete Skin & Hair Care Under One Roof</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">From hair restoration to clinical and cosmetic dermatology -- evidence-based care for every member of your family, right here in KK Nagar.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredServices.map((service, i) => (
        <ServiceCard 
          image={getServiceImage(service.slug)}
          alt={getServiceImageAlt(service.slug, service.alt)}
          title={service.title} 
          description={service.description}
          link={service.link}
          priority={i < 3}
        />
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/services" class="inline-block text-brand-700 font-bold hover:underline">View all services &rarr;</a>
    </div>
  </section>

  <section class="py-16 px-6 max-w-7xl mx-auto bg-champagne-50 rounded-3xl" id="conditions">
    <div class="text-center mb-12 pt-4">
      <h2 class="text-3xl md:text-4xl font-extrabold text-brand-900 mb-4">Conditions We Treat</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">A closer look at the specific hair, skin, and paediatric conditions our doctors diagnose and manage every day.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-2 pb-4">
      {featuredConditions.map((condition) => (
        <a href={`/conditions/${condition.slug}`} class="bg-white rounded-2xl border border-champagne-200 p-6 hover:shadow-xl hover:border-brand-200 transition-all duration-300 group flex flex-col h-full">
          <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-brand-700 transition-colors">{condition.data.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-4 flex-grow">{condition.data.heroSubheadline}</p>
          <span class="text-brand-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
            Learn More <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))}
    </div>

    <div class="text-center pb-4">
      <a href="/conditions" class="inline-block text-brand-700 font-bold hover:underline">View all conditions &rarr;</a>
    </div>
  </section>

  <section class="bg-white py-16 px-6 border-y border-champagne-200">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-8 text-brand-900">Dealing With a Skin or Hair Concern?</h2>
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <span class="bg-brand-50 text-brand-800 px-4 py-2 rounded-full font-medium">Hair Fall</span>
        <span class="bg-brand-50 text-brand-800 px-4 py-2 rounded-full font-medium">Persistent Acne</span>
        <span class="bg-brand-50 text-brand-800 px-4 py-2 rounded-full font-medium">Pigmentation</span>
        <span class="bg-brand-50 text-brand-800 px-4 py-2 rounded-full font-medium">Itchy or Scaly Skin</span>
        <span class="bg-brand-50 text-brand-800 px-4 py-2 rounded-full font-medium">Skin Allergies</span>
      </div>
      <p class="text-lg text-slate-600 mb-6">Early diagnosis leads to simpler, more effective treatment.</p>
      <a href="/book" class="text-brand-600 font-bold hover:underline">Contact us now →</a>
    </div>
  </section>

  <section class="py-16 px-6 max-w-6xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-4 text-brand-900">Meet Our Doctors</h2>
    <p class="text-lg text-slate-700 mb-10 leading-relaxed max-w-3xl mx-auto">
      Three AIIMS-trained consultant dermatologists with expertise spanning hair transplantation, clinical and cosmetic dermatology, and paediatric skin care. We are committed to providing ethical, evidence-based treatment, prioritizing your long-term skin and hair health over high-volume transactions.
    </p>

    <div id="doctorGridHome" class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {siteConfig.doctors.map((doctor) => (
        <a href={`/our-doctors/${doctor.slug}`} class="bg-white rounded-2xl shadow-sm border border-champagne-200 overflow-hidden hover:shadow-xl hover:border-brand-200 transition-all duration-300 group flex flex-col">
          <div class="aspect-[3/4] bg-champagne-100 overflow-hidden">
            <img
              src={`/images/doctors/${doctor.slug}.jpg`}
              alt={`${doctor.name}, ${doctor.designation}`}
              width="400"
              height="533"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              onerror={`this.onerror=null;this.src='https://placehold.co/400x533/EEF0F6/223154?text=${encodeURIComponent(doctor.name)}'`}
            />
          </div>
          <div class="p-6 flex flex-col flex-grow text-left">
            <h3 class="text-xl font-bold text-brand-900 mb-1">{doctor.name}</h3>
            <p class="text-sm text-brand-600 font-semibold mb-1">{doctor.designation}</p>
            <p class="text-xs text-slate-500 font-semibold uppercase tracking-wide mb-4">{doctor.qualificationsShort}</p>
            <span class="text-brand-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
              View Profile <span aria-hidden="true">&rarr;</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    <a href="/our-doctors" class="inline-block mt-8 bg-brand-100 text-brand-800 px-6 py-2 rounded-md font-semibold hover:bg-brand-200 transition">View All Doctors</a>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const grid = document.getElementById('doctorGridHome');
      if (!grid) return;
      const cards = Array.from(grid.children);
      for (let i = cards.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [cards[i], cards[j]] = [cards[j], cards[i]];
      }
      cards.forEach((card) => grid.appendChild(card));
    });
  </script>

  <Testimonials />

  {latestPosts.length > 0 && (
    <section class="bg-champagne-50 py-20 px-6 border-t border-champagne-200">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center md:items-end mb-10 gap-4 text-center md:text-left">
          <div>
            <h2 class="text-3xl font-bold text-brand-900 mb-2">Skin & Hair Health Blog</h2>
            <p class="text-lg text-slate-600">Patient guides and clinical insights from our doctors.</p>
          </div>
          <a href="/blog" class="text-brand-600 font-bold hover:underline flex items-center gap-1 hidden md:flex">
            View All Posts <span aria-hidden="true">→</span>
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="bg-white rounded-2xl shadow-sm border border-champagne-200 hover:shadow-xl hover:border-brand-200 transition-all duration-300 group flex flex-col h-full p-6 md:p-8 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-1.5 h-full bg-brand-600 group-hover:bg-brand-700 transition-colors"></div>
              <p class="text-xs text-brand-600 mb-3 font-bold uppercase tracking-wider">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                {post.data.tags && post.data.tags.length > 0 && (
                  <span class="text-slate-400"> &middot; {post.data.tags[0]}</span>
                )}
              </p>
              <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-brand-600 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-slate-600 text-sm mb-6 line-clamp-3 flex-grow leading-relaxed">
                {post.data.description}
              </p>
              <span class="text-brand-600 font-semibold text-sm mt-auto flex items-center gap-1 group-hover:gap-2 transition-all">
                Read Article <span aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
        
        <div class="mt-10 text-center md:hidden">
           <a href="/blog" class="inline-block bg-white text-brand-600 font-bold px-8 py-3 rounded-md shadow-sm border border-champagne-200 w-full">View All Posts</a>
        </div>
      </div>
    </section>
  )}

  <FAQ limit={5} />

  <ClinicGallery />

  <section class="py-16 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-brand-900 mb-4">Find Us in KK Nagar</h2>
      <p class="text-lg text-slate-600">Conveniently located for patients in Ashok Nagar, Vadapalani, Virugambakkam, and Ramapuram.</p>
    </div>
    
    <div class="w-full aspect-video md:aspect-[21/9] rounded-2xl overflow-hidden shadow-lg border border-champagne-200">
      <iframe 
        title={`Google Maps Location for ${siteConfig.name}`}
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3886.974836067086!2d80.2017997!3d13.0397028!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a5266cb2eb18fbb%3A0xc6fbef0f8eee3a3f!2s39%2F2%2C%20RK%20Shanmugam%20Salai%2C%20Goutham%20Colony%2C%20K.%20K.%20Nagar%2C%20Chennai%2C%20Tamil%20Nadu%20600078!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
  </section>

  <BookingSection defaultService="General Consultation" />
</MainLayout>
