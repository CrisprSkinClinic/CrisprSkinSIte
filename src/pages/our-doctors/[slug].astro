---
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../config/site.js';

export async function getStaticPaths() {
  return siteConfig.doctors.map((doctor) => ({
    params: { slug: doctor.slug },
    props: { doctor },
  }));
}

const { doctor } = Astro.props;

const pageTitle = `${doctor.name} - ${doctor.designation}`;
const pageDescription = `${doctor.name}, ${doctor.qualificationsShort}, is a ${doctor.designation} at ${siteConfig.name}, KK Nagar, Chennai. Call ${siteConfig.contact.phone} to book.`;
---

<MainLayout title={pageTitle} description={pageDescription} image="/images/hero-doctor.jpg">
  <Breadcrumbs items={[
    { name: "Our Doctors", url: "/our-doctors" },
    { name: doctor.name, url: `/our-doctors/${doctor.slug}` }
  ]} />

  <div class="bg-brand-900 text-white py-20 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-12 items-center">
      <div class="md:w-1/3">
        <div class="bg-white/10 aspect-[3/4] rounded-2xl shadow-xl flex items-center justify-center overflow-hidden border border-white/20">
          <img
            src={`/images/doctors/${doctor.slug}.jpg`}
            alt={doctor.name}
            class="w-full h-full object-cover"
            onerror={`this.src='https://placehold.co/400x533/234B3A/FAF8F5?text=${encodeURIComponent(doctor.name)}'`}
          />
        </div>
      </div>
      <div class="md:w-2/3">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-2">{doctor.name}</h1>
        <p class="text-xl text-brand-300 font-bold mb-2 tracking-wide">{doctor.designation}</p>
        <p class="text-sm text-champagne-200 font-semibold uppercase tracking-widest mb-6">{doctor.qualificationsShort}</p>
        <p class="text-lg opacity-90 leading-relaxed mb-6">
          {doctor.bio}
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href={siteConfig.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="bg-emerald-500 text-white px-6 py-2 rounded-md font-bold hover:bg-emerald-600 transition shadow-lg flex items-center gap-2">
            Chat on WhatsApp
          </a>
          <a href="/book" data-track="booking-click" class="bg-gold-500 text-brand-900 px-6 py-2 rounded-md font-bold hover:bg-gold-600 transition shadow-lg flex items-center gap-2">
            Book a Consultation
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto py-20 px-6">
    <section>
      <h2 class="text-3xl font-bold text-brand-900 mb-4 border-b border-champagne-200 pb-4">Qualifications</h2>
      <p class="text-lg text-slate-700 leading-relaxed mb-12">{doctor.qualifications}</p>
    </section>

    <section>
      <h2 class="text-3xl font-bold text-brand-900 mb-8 border-b border-champagne-200 pb-4">Areas of Expertise</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {doctor.expertise.map((item) => (
          <div class="bg-champagne-50 px-5 py-4 rounded-xl border border-champagne-200 flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-slate-800 font-medium">{item}</span>
          </div>
        ))}
      </div>
    </section>
  </div>

  <CTA
    title={`Book a Consultation with ${doctor.name}`}
    address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
    phone={siteConfig.contact.phone}
    doctorName={doctor.name}
  />
</MainLayout>
