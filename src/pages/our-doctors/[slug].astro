---
import MainLayout from '../../layouts/MainLayout.astro';
import CTA from '../../components/CTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../config/site.js';

export async function getStaticPaths() {
 return siteConfig.doctors.map((doctor) => ({
  params: { slug: doctor.slug },
  props: { doctor },
 }));
}

const { doctor } = Astro.props;

const pageTitle = `${doctor.name} - ${doctor.designation}`;
const pageDescription = `${doctor.name}, ${doctor.qualificationsShort}, is a ${doctor.designation} at ${siteConfig.name}, KK Nagar, Chennai. Call ${siteConfig.contact.phone} to book.`;
---

<MainLayout title={pageTitle} description={pageDescription} image="/images/hero-doctor.jpg">
 <Breadcrumbs items={[
  { name: "Our Doctors", url: "/our-doctors" },
  { name: doctor.name, url: `/our-doctors/${doctor.slug}` }
 ]} />

 <div class="bg-paper-50 border-b border-stone-400/15 pt-8 pb-16 md:pb-24 px-6">
  <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 items-end">
   <div class="md:col-span-4">
    <div class="border border-stone-400/15 aspect-[3/4] overflow-hidden">
     <img
      src={`/images/doctors/${doctor.slug}.jpg`}
      alt={doctor.name}
      class="w-full h-full object-cover"
      onerror={`this.src='https://placehold.co/400x533/F3F0F6/1A1D1F?text=${encodeURIComponent(doctor.name)}'`}
     />
    </div>
   </div>
   <div class="md:col-span-8">
    <h1 class="font-display text-4xl md:text-5xl font-medium mb-3 text-ink">{doctor.name}</h1>
    <p class="text-lg text-brand-600 mb-2">{doctor.designation}</p>
    <p class="text-xs text-stone-500 uppercase tracking-[0.15em] mb-6">{doctor.qualificationsShort}</p>
    <p class="text-lg text-stone-600 leading-relaxed mb-8 max-w-xl">
     {doctor.bio}
    </p>
    <div class="flex gap-4 flex-wrap">
     <a href={siteConfig.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="border border-stone-400/30 text-ink px-6 py-3 hover:border-ink transition-colors duration-300 flex items-center gap-2 text-sm">
      Chat on WhatsApp
     </a>
     <a href="/book" data-track="booking-click" class="bg-ink text-white px-6 py-3 hover:bg-brand-600 transition-colors duration-300 flex items-center gap-2 text-sm">
      Book a Consultation
     </a>
    </div>
   </div>
  </div>
 </div>

 <div class="max-w-4xl mx-auto py-20 px-6">
  <section>
   <h2 class="font-display text-2xl font-medium text-ink mb-4 pb-4 border-b border-stone-400/15">Qualifications</h2>
   <p class="text-lg text-stone-600 leading-relaxed mb-16">{doctor.qualifications}</p>
  </section>

  <section>
   <h2 class="font-display text-2xl font-medium text-ink mb-8 pb-4 border-b border-stone-400/15">Areas of Expertise</h2>
   <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-stone-400/15 border border-stone-400/15">
    {doctor.expertise.map((item) => (
     <div class="bg-white px-5 py-4 flex items-center gap-3">
      <span class="w-1 h-1 rounded-full bg-brand-500 shrink-0"></span>
      <span class="text-stone-700">{item}</span>
     </div>
    ))}
   </div>
  </section>
 </div>

 <CTA
  title={`Book a Consultation with ${doctor.name}`}
  address={`${siteConfig.contact.address.street}, ${siteConfig.contact.address.locality} - ${siteConfig.contact.address.postalCode}`}
  phone={siteConfig.contact.phone}
  doctorName={doctor.name}
 />
</MainLayout>
