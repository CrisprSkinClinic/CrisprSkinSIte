---
// src/pages/register.astro
//
// Public patient self-registration form. Submissions go into
// patient_registration_requests (via public-patient-registration.js),
// NOT directly into the real patients table -- every submission
// requires staff approval in Bookings Manager before becoming a real
// patient record. This page uses MainLayout (with the site's normal
// header/footer), unlike bookings-manager.astro's AppLayout, since
// this is a genuine public-facing page, not an internal staff tool.
//
// Field set is Step 1 ("Personal Information") of the intake wizard
// prototype -- salutation/first/last name, DOB with auto-age, gender
// (auto-suggested from salutation), email, phone, address, pincode,
// occupation, referral source. All required, matching the wizard.
// Steps 2-5 of the wizard (health background, symptom picker,
// diagnosis questions, consent) are a separate, not-yet-built
// feature (planned /intake?appointment_id=<uuid> page) and are
// intentionally NOT part of this page.
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.js';
---

<MainLayout title={`Patient Registration | ${siteConfig.name}`} description="Register as a new patient at CRISPR Skin and Hair Clinic ahead of your visit.">
  <div class="max-w-2xl mx-auto py-16 px-6">
    <h1 class="text-3xl md:text-4xl font-extrabold text-brand-900 mb-3 text-center">Patient Registration</h1>
    <p class="text-slate-600 text-center mb-10">
      Register your details ahead of your visit. Our front desk will review and confirm your registration -- there's nothing further you need to do after submitting.
    </p>

    <div id="reg-form-container" class="bg-white rounded-2xl shadow-sm border border-champagne-200 p-8 md:p-10">
      <form id="reg-form" class="space-y-5">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="reg-salutation" class="text-sm font-semibold text-slate-700 mb-1 block">Salutation *</label>
            <select id="reg-salutation" required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition">
              <option value="">Select</option>
              <option value="Mr.">Mr.</option>
              <option value="Ms.">Ms.</option>
              <option value="Mrs.">Mrs.</option>
              <option value="Dr.">Dr.</option>
              <option value="Master">Master</option>
              <option value="Baby">Baby</option>
            </select>
          </div>
          <div>
            <label for="reg-gender" class="text-sm font-semibold text-slate-700 mb-1 block">Gender *</label>
            <select id="reg-gender" required
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition">
              <option value="">Select</option>
              <option value="male">Male</option>
              <option value="female">Female</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="reg-first-name" class="text-sm font-semibold text-slate-700 mb-1 block">First Name *</label>
            <input type="text" id="reg-first-name" required placeholder="First name"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
          <div>
            <label for="reg-last-name" class="text-sm font-semibold text-slate-700 mb-1 block">Last Name *</label>
            <input type="text" id="reg-last-name" required placeholder="Last name"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="reg-dob" class="text-sm font-semibold text-slate-700 mb-1 block">Date of Birth *</label>
            <input type="text" id="reg-dob" required placeholder="DD/MM/YYYY"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
            <p id="reg-dob-error" class="text-slate-500 text-xs mt-1 min-h-[1rem]"></p>
          </div>
          <div>
            <label for="reg-age" class="text-sm font-semibold text-slate-700 mb-1 block">Age</label>
            <input type="text" id="reg-age" readonly placeholder="Auto-calculated"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl bg-slate-50 text-slate-500" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="reg-email" class="text-sm font-semibold text-slate-700 mb-1 block">Email Address *</label>
            <input type="email" id="reg-email" required placeholder="name@domain.com"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
          <div>
            <label for="reg-phone" class="text-sm font-semibold text-slate-700 mb-1 block">Phone Number *</label>
            <input type="tel" id="reg-phone" required placeholder="9876543210"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
        </div>

        <div>
          <label for="reg-address" class="text-sm font-semibold text-slate-700 mb-1 block">Address *</label>
          <textarea id="reg-address" required rows="3" placeholder="Your complete address (min 20 characters)"
                    class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition"></textarea>
          <p id="reg-address-counter" class="text-slate-500 text-xs mt-1">0/20 characters</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label for="reg-pincode" class="text-sm font-semibold text-slate-700 mb-1 block">Pincode *</label>
            <input type="text" id="reg-pincode" required placeholder="600078" maxlength="6"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
          <div>
            <label for="reg-occupation" class="text-sm font-semibold text-slate-700 mb-1 block">Occupation *</label>
            <input type="text" id="reg-occupation" required placeholder="Your occupation"
                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
          </div>
        </div>

        <div>
          <label for="reg-referral" class="text-sm font-semibold text-slate-700 mb-1 block">How did you hear about us? *</label>
          <select id="reg-referral" required
                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition">
            <option value="">Select</option>
            <option value="Friend/Family Referral">Friend/Family Referral</option>
            <option value="Doctor Referral">Doctor Referral</option>
            <option value="Google Search">Google Search</option>
            <option value="Social Media">Social Media</option>
            <option value="Practo">Practo</option>
            <option value="Walk-in">Walk-in</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div id="reg-referral-other-group" class="hidden">
          <label for="reg-referral-other" class="text-sm font-semibold text-slate-700 mb-1 block">Please specify *</label>
          <input type="text" id="reg-referral-other" placeholder="How did you hear about us?"
                 class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:border-brand-500 focus:ring-2 focus:ring-brand-100 outline-none transition" />
        </div>

        <button type="submit" id="reg-submit-btn"
                class="w-full bg-brand-900 hover:bg-brand-800 text-white font-bold py-3.5 rounded-xl shadow-lg transition active:scale-[0.98]">
          Submit Registration
        </button>
        <p id="reg-error" class="text-red-600 text-sm text-center min-h-[1.25rem]"></p>
      </form>
    </div>

    <!-- Shown after successful submission, replacing the form -->
    <div id="reg-success-container" class="hidden bg-white rounded-2xl shadow-sm border border-champagne-200 p-10 text-center">
      <div class="w-14 h-14 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
      </div>
      <h2 class="text-xl font-bold text-slate-900 mb-2">Registration Submitted</h2>
      <p class="text-slate-600">
        Thank you -- your registration has been received and is pending review by our front desk. You'll be confirmed as a registered patient at your next visit, or you're welcome to call us at
        <a href={`tel:${siteConfig.contact.phone}`} class="text-brand-600 font-semibold hover:underline">{siteConfig.contact.phone}</a>
        if you have any questions in the meantime.
      </p>
    </div>
  </div>
</MainLayout>

<script is:inline>
  // --- DOB -> age, matching the wizard's DD/MM/YYYY parsing ---
  function parseDOB(str) {
    const parts = String(str || '').match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (!parts) return null;
    const d = new Date(parts[3], parts[2] - 1, parts[1]);
    return Number.isNaN(d.getTime()) ? null : d;
  }

  function calculateAge() {
    const dobInput = document.getElementById('reg-dob');
    const ageInput = document.getElementById('reg-age');
    const dobError = document.getElementById('reg-dob-error');
    const dobDate = parseDOB(dobInput.value);

    if (!dobInput.value) {
      dobError.textContent = '';
      ageInput.value = '';
      return;
    }
    if (!dobDate) {
      dobError.textContent = 'Enter a valid date (DD/MM/YYYY)';
      ageInput.value = '';
      return;
    }
    const today = new Date();
    let age = today.getFullYear() - dobDate.getFullYear();
    const monthDiff = today.getMonth() - dobDate.getMonth();
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dobDate.getDate())) age--;
    if (age < 0 || age > 120) {
      dobError.textContent = 'Enter a valid date (DD/MM/YYYY)';
      ageInput.value = '';
      return;
    }
    dobError.textContent = '';
    ageInput.value = `${age} years`;
  }

  document.getElementById('reg-dob').addEventListener('input', calculateAge);
  document.getElementById('reg-dob').addEventListener('blur', calculateAge);

  // --- Salutation -> gender auto-suggestion, same mapping as the wizard ---
  document.getElementById('reg-salutation').addEventListener('change', (e) => {
    const genderSelect = document.getElementById('reg-gender');
    const s = e.target.value;
    if (s === 'Mr.' || s === 'Master') genderSelect.value = 'male';
    else if (s === 'Ms.' || s === 'Mrs.' || s === 'Baby') genderSelect.value = 'female';
  });

  // --- Referral "Other" follow-up ---
  document.getElementById('reg-referral').addEventListener('change', (e) => {
    const group = document.getElementById('reg-referral-other-group');
    const otherInput = document.getElementById('reg-referral-other');
    const isOther = e.target.value === 'Other';
    group.classList.toggle('hidden', !isOther);
    otherInput.required = isOther;
    if (!isOther) otherInput.value = '';
  });

  // --- Address character counter ---
  document.getElementById('reg-address').addEventListener('input', (e) => {
    document.getElementById('reg-address-counter').textContent = `${e.target.value.length}/20 characters`;
  });

  // --- Phone / pincode: digits only, length-capped ---
  document.getElementById('reg-phone').addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/[^0-9]/g, '').slice(0, 10);
  });
  document.getElementById('reg-pincode').addEventListener('input', (e) => {
    e.target.value = e.target.value.replace(/[^0-9]/g, '').slice(0, 6);
  });

  document.getElementById('reg-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errorEl = document.getElementById('reg-error');
    const btn = document.getElementById('reg-submit-btn');
    errorEl.textContent = '';

    const salutation = document.getElementById('reg-salutation').value;
    const firstName = document.getElementById('reg-first-name').value.trim();
    const lastName = document.getElementById('reg-last-name').value.trim();
    const dob = document.getElementById('reg-dob').value.trim();
    const gender = document.getElementById('reg-gender').value;
    const email = document.getElementById('reg-email').value.trim();
    const phone = document.getElementById('reg-phone').value.trim();
    const address = document.getElementById('reg-address').value.trim();
    const pincode = document.getElementById('reg-pincode').value.trim();
    const occupation = document.getElementById('reg-occupation').value.trim();
    const referralSource = document.getElementById('reg-referral').value;
    const referralOtherDetails = document.getElementById('reg-referral-other').value.trim();

    if (!salutation) { errorEl.textContent = 'Please select a salutation.'; return; }
    if (!firstName || !lastName) { errorEl.textContent = 'Please enter your first and last name.'; return; }
    if (!parseDOB(dob)) { errorEl.textContent = 'Please enter a valid date of birth (DD/MM/YYYY).'; return; }
    if (!gender) { errorEl.textContent = 'Please select a gender.'; return; }
    if (!/^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.(com|in)$/.test(email)) { errorEl.textContent = 'Please enter a valid email address.'; return; }
    if (!/^[6-9][0-9]{9}$/.test(phone)) { errorEl.textContent = 'Please enter a valid 10-digit phone number.'; return; }
    if (address.length < 20) { errorEl.textContent = 'Address must be at least 20 characters.'; return; }
    if (!/^[0-9]{6}$/.test(pincode)) { errorEl.textContent = 'Please enter a valid 6-digit pincode.'; return; }
    if (!occupation) { errorEl.textContent = 'Please enter your occupation.'; return; }
    if (!referralSource) { errorEl.textContent = 'Please let us know how you heard about us.'; return; }
    if (referralSource === 'Other' && !referralOtherDetails) { errorEl.textContent = 'Please specify how you heard about us.'; return; }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    try {
      const response = await fetch('/.netlify/functions/public-patient-registration', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          salutation,
          firstName,
          lastName,
          name: `${salutation} ${firstName} ${lastName}`.trim(),
          dob,
          gender,
          email,
          phone,
          address,
          pincode,
          occupation,
          referralSource,
          referralOtherDetails: referralSource === 'Other' ? referralOtherDetails : '',
        }),
      });
      const result = await response.json();
      if (!response.ok || !result.success) {
        throw new Error(result.error || 'Something went wrong. Please try again.');
      }
      document.getElementById('reg-form-container').classList.add('hidden');
      document.getElementById('reg-success-container').classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = err.message;
    } finally {
      btn.disabled = false;
      btn.textContent = 'Submit Registration';
    }
  });
</script>
