---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import BookingSection from '../../components/LandingPageSections/BookingSection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { siteConfig } from '../../config/site.js';
import { getServiceImage } from '../../utils/serviceImages';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;

const optimizedHero = getServiceImage(data.heroImage);
const heroImageSrc = data.heroImage
  ? `/images/services/${data.heroImage}.jpg`
  : null;

const conditionEntries = data.conditionsManaged
  ? (await Promise.all(
      data.conditionsManaged.map((slug) => getEntry('conditions', slug))
    )).filter(Boolean)
  : [];

let faqEntries = [];
if (data.faqIds && data.faqIds.length > 0) {
  const resolved = await Promise.all(
    data.faqIds.map((id) => getEntry('faqs', id))
  );
  faqEntries = resolved
    .filter(Boolean)
    .map((f) => ({ question: f.data.question, answer: f.body }));
}

const relatedDoctor = data.defaultDoctorId
  ? siteConfig.doctors.find((d) => d.dbId === data.defaultDoctorId)
  : null;

const pageUrl = new URL(`/services/${entry.slug}`, siteConfig.url).toString();

const faqSchema = faqEntries.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqEntries.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer,
    },
  })),
} : null;

const medicalWebPageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": data.title,
  "description": data.metaDescription,
  "url": pageUrl,
  "medicalAudience": {
    "@type": "MedicalAudience",
    "audienceType": "Patient",
  },
  ...(data.treatments && data.treatments.length > 0 && {
    "about": data.treatments.map((t) => ({
      "@type": "MedicalTherapy",
      "name": t.name,
      "description": t.description,
    })),
  }),
};
---

<MainLayout title={data.title} description={data.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(medicalWebPageSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Breadcrumbs items={[
    { name: "Services", url: "/services" },
    { name: data.title, url: `/services/${entry.slug}` }
  ]} />

  <section class="bg-brand-900 text-white py-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-1/2">
        {data.heroEyebrow && (
          <span class="text-brand-300 font-bold tracking-wider uppercase text-sm mb-4 block">{data.heroEyebrow}</span>
        )}
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">{data.heroHeadline}</h1>
        <p class="text-xl text-brand-100 mb-8 leading-relaxed">
          {data.heroSubheadline}
        </p>
        <a href="#book" class="bg-white text-brand-900 font-bold px-8 py-3 rounded-md shadow-lg hover:bg-brand-50 transition inline-block">
          {data.ctaTitle || `Book a ${data.title} Evaluation`}
        </a>
      </div>

      {optimizedHero ? (
        <div class="md:w-1/2 w-full">
          <div class="rounded-2xl shadow-2xl border-4 border-white/10 bg-brand-800 overflow-hidden aspect-square">
            <Image
              src={optimizedHero}
              alt={data.heroHeadline}
              width={700}
              height={700}
              widths={[400, 700]}
              sizes="(max-width: 768px) 100vw, 50vw"
              formats={['avif', 'webp']}
              quality={80}
              loading="eager"
              class="w-full h-full object-contain"
            />
          </div>
        </div>
      ) : heroImageSrc && (
        <div class="md:w-1/2 w-full">
          <div class="rounded-2xl shadow-2xl border-4 border-white/10 bg-brand-800 overflow-hidden aspect-square">
            <img
              src={heroImageSrc}
              alt={data.heroHeadline}
              width="700"
              height="700"
              class="w-full h-full object-contain"
              onerror={`this.onerror=null;this.src='https://placehold.co/700x700/0f172a/ffffff?text=${encodeURIComponent(data.title)}'`}
            />
          </div>
        </div>
      )}
    </div>
  </section>

  {data.twoPaths && (
    <section class="py-16 px-6 max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-brand-50 border border-brand-100 p-8 rounded-xl">
          <h2 class="text-xl font-bold text-brand-900 mb-3">{data.twoPaths.screeningTitle}</h2>
          <p class="text-slate-700 leading-relaxed">{data.twoPaths.screeningBody}</p>
        </div>
        <div class="bg-red-50 border border-red-200 p-8 rounded-xl">
          <h2 class="text-xl font-bold text-red-900 mb-3">{data.twoPaths.symptomsTitle}</h2>
          <p class="text-red-800 leading-relaxed">{data.twoPaths.symptomsBody}</p>
        </div>
      </div>
    </section>
  )}

  <section class="py-8 px-6 max-w-4xl mx-auto">
    <div class="prose prose-lg prose-blue max-w-none text-slate-700">
      <Content />
    </div>
  </section>

  {data.diagnostics && data.diagnostics.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-brand-900 mb-6">How We Evaluate</h2>
      <ul class="list-disc pl-6 space-y-2 text-slate-700">
        {data.diagnostics.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  )}

  {data.treatments && data.treatments.length > 0 && (
    <section class="py-8 px-6 max-w-4xl mx-auto">
      <div class="bg-brand-50 p-8 rounded-xl border border-brand-100">
        <h2 class="text-2xl font-bold text-brand-900 mb-4">Treatment Options</h2>
        <ul class="space-y-3">
          {data.treatments.map((t) => (
            <li>
              <strong class="text-brand-900">{t.name}:</strong>{' '}
              <span class="text-slate-700">{t.description}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {conditionEntries.length > 0 && (
    <section class="py-12 px-6 max-w-4xl mx-auto border-t border-slate-200">
      <h2 class="text-2xl font-bold text-brand-900 mb-6">Conditions We Manage</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {conditionEntries.map((c) => (
          <a href={`/conditions/${c.slug}`} class="block p-5 rounded-xl bg-champagne-50 hover:bg-slate-100 transition-colors">
            <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mb-1">Condition</p>
            <p class="font-semibold text-slate-900">{c.data.title}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {relatedDoctor && (
    <section class="py-12 px-6 max-w-4xl mx-auto border-t border-slate-200">
      <h2 class="text-2xl font-bold text-brand-900 mb-6">Performed by</h2>
      <a
        href={`/our-doctors/${relatedDoctor.slug}`}
        class="flex items-center gap-5 p-5 rounded-xl bg-champagne-50 hover:bg-slate-100 border border-champagne-200 transition-colors group"
      >
        <img
          src={`/images/doctors/${relatedDoctor.slug}.jpg`}
          alt={relatedDoctor.name}
          width="80"
          height="80"
          class="w-20 h-20 rounded-full object-cover border-2 border-white shadow"
          onerror={`this.src='https://placehold.co/80x80/223154/FAF8F5?text=${encodeURIComponent(relatedDoctor.name.split(' ').pop())}'`}
        />
        <div>
          <p class="font-bold text-slate-900 group-hover:text-brand-700 transition-colors">{relatedDoctor.name}</p>
          <p class="text-sm text-brand-600 font-semibold">{relatedDoctor.designation}</p>
          <p class="text-xs text-slate-500 mt-1">{relatedDoctor.qualificationsShort}</p>
        </div>
        <span class="ml-auto text-brand-600 font-semibold text-sm hidden sm:inline">View profile →</span>
      </a>
    </section>
  )}

  <FAQAccordion entries={faqEntries} />

  <BookingSection defaultService={data.defaultService} defaultDoctorId={data.defaultDoctorId} />
</MainLayout>
