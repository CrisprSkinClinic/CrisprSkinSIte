---
import MainLayout from '../../layouts/MainLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site.js';
import { getServiceImage } from '../../utils/serviceImages';

const pageTitle = "All Services";
const pageDescription = `Complete list of dermatology, hair, and cosmetic services offered at ${siteConfig.name}, KK Nagar, Chennai.`;

const allServices = await getCollection('services');

const categoryLabels = {
  hair: 'Hair',
  skin: 'Skin',
  cosmetic: 'Cosmetic',
  pediatric: 'Pediatric',
};

const categoryOrder = ['hair', 'skin', 'cosmetic', 'pediatric'];

const servicesByCategory = categoryOrder.map((cat) => ({
  category: cat,
  label: categoryLabels[cat],
  services: allServices
    .filter((s) => s.data.category === cat)
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Breadcrumbs items={[{ name: "Services", url: "/services" }]} />

  <div class="bg-brand-900 text-white py-16 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">All Services</h1>
    <p class="text-lg text-brand-200 max-w-2xl mx-auto">Evidence-based hair, skin, cosmetic, and paediatric dermatology care under one roof in KK Nagar, Chennai.</p>
  </div>

  <div class="max-w-7xl mx-auto py-16 px-6">
    {servicesByCategory.map(({ category, label, services }) => (
      services.length > 0 && (
        <section class="mb-16 last:mb-0">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-2xl md:text-3xl font-bold text-brand-900">{label}</h2>
            <a href={`/${category}`} class="text-sm text-brand-600 font-semibold hover:underline">View {label} overview &rarr;</a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {services.map((service) => (
              <ServiceCard
                image={getServiceImage(service.data.heroImage) ?? (service.data.heroImage ? `/images/services/${service.data.heroImage}.jpg` : undefined)}
                alt={service.data.title}
                title={service.data.title}
                description={service.data.heroSubheadline || service.data.metaDescription || ''}
                link={`/services/${service.slug}`}
              />
            ))}
          </div>
        </section>
      )
    ))}
  </div>
</MainLayout>
