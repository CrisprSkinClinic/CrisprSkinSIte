---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site.js';
---

<MainLayout title={`Request Received | ${siteConfig.name}`}>
 <div class="min-h-[60vh] flex items-center justify-center py-20 px-6">
  <div class="max-w-md w-full bg-white border border-stone-400/15 p-10 md:p-12 text-center">
   <div class="w-14 h-14 border border-brand-500 text-brand-500 flex items-center justify-center mx-auto mb-8">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
   </div>
   <h1 class="font-display text-3xl font-medium text-ink mb-4">Request Received</h1>
   <p class="text-stone-600 mb-10 leading-relaxed">
    Thank you for reaching out to {siteConfig.name}. Our front desk staff will contact you shortly at the phone number provided to confirm your exact appointment time.
   </p>
   <a href="/" class="inline-block bg-ink text-white text-sm px-8 py-3.5 hover:bg-brand-600 transition-colors duration-300">
    Return to Homepage
   </a>
  </div>
 </div>
</MainLayout>
